---
---

<div id="redirect-overlay" class="fixed inset-0 z-[9999] bg-[#E8E8E3] dark:bg-[#1C1C1A] flex flex-col items-center justify-center p-6 overflow-hidden transition-colors duration-300">
  
  <div class="relative w-full max-w-2xl bg-[#E8E8E3] dark:bg-[#1C1C1A] border-4 border-black dark:border-white p-10 md:p-14 text-center shadow-[8px_8px_0_0_#000] dark:shadow-[8px_8px_0_0_#fff]">
    
    <!-- Tech Accent Top -->
    <div class="absolute top-0 left-0 w-full flex justify-between p-2 px-4 font-mono text-[10px] sm:text-xs opacity-70 border-b-4 border-black dark:border-white text-black dark:text-white uppercase font-bold">
      <span>System.Update //</span>
      <span>Status: Redirecting</span>
    </div>

    <!-- Main Content -->
    <div class="mt-8 mb-8">
      <h1 class="font-sans font-black text-4xl md:text-5xl lg:text-6xl uppercase tracking-tighter text-black dark:text-white mb-6 leading-tight">
        Porfolio <br/> Actualizado
      </h1>
      
      <p id="status-text" class="font-mono text-sm md:text-base text-black dark:text-white opacity-80 uppercase leading-relaxed mb-10 max-w-lg mx-auto font-bold">
        He migrado mi porfolio a una nueva versión. <br/> Serás redirigido automáticamente en <br/><br/>
        <span id="countdown" class="text-6xl md:text-7xl font-black text-black dark:text-white tracking-tighter block mt-4">5</span>
      </p>
    </div>

    <!-- Buttons -->
    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center pb-4">
      <a href="https://porfolio-pablo-torres.vercel.app/" id="redirect-link" class="w-full sm:w-auto bg-black dark:bg-white text-[#E8E8E3] dark:text-[#1C1C1A] px-8 py-4 font-sans font-bold uppercase tracking-widest text-sm hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors duration-300 flex items-center justify-center gap-2 group border-2 border-black dark:border-white">
        <span>Ir al nuevo</span>
        <span class="inline-block transform group-hover:translate-x-1 transition-transform">-&gt;</span>
      </a>
      <button id="cancel-btn" class="w-full sm:w-auto bg-transparent border-2 border-black dark:border-white text-black dark:text-white px-8 py-4 font-sans font-bold uppercase tracking-widest text-sm hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-300">
        Quedarme aquí
      </button>
    </div>

    <!-- Tech Accent Bottom -->
    <div class="absolute bottom-0 left-0 w-full p-2 px-4 font-mono text-[10px] sm:text-xs opacity-70 border-t-4 border-black dark:border-white text-black dark:text-white text-left uppercase font-bold">
      DATA STREAM // V2.0
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    let timeLeft = 5;
    let timer = null;
    const overlay = document.getElementById('redirect-overlay');
    const countdownEl = document.getElementById('countdown');
    const cancelBtn = document.getElementById('cancel-btn');
    const redirectUrl = "https://porfolio-pablo-torres.vercel.app/";

    function startTimer() {
      timer = window.setInterval(() => {
        timeLeft -= 1;
        if (countdownEl) countdownEl.textContent = timeLeft.toString();
        
        if (timeLeft <= 0) {
          if (timer) window.clearInterval(timer);
          window.location.href = redirectUrl;
        }
      }, 1000);
    }

    if (cancelBtn) {
      cancelBtn.addEventListener('click', () => {
        if (timer) window.clearInterval(timer);
        if (overlay) overlay.style.display = 'none';
      });
    }

    if (overlay) {
      startTimer();
    }
  })();
</script>
